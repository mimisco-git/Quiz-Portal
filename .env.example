# ─── LOCAL DEVELOPMENT ──────────────────────────────────────────────
# SQLite file used when TURSO_DATABASE_URL is not set.
# Path is relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# JWT signing secret — use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"

# Initial lecturer password set when the database is seeded for the first time.
# Change this immediately after the first login. Defaults to "ChangeMe@2026!" if not set.
SEED_LECTURER_PASSWORD="ChangeMe@2026!"

# ─── PRODUCTION (Turso) ─────────────────────────────────────────────
# Set these in Vercel → Settings → Environment Variables.
# Leave blank locally; the app falls back to the SQLite file above.

# Your Turso database URL — format: libsql://<db-name>-<org>.turso.io
TURSO_DATABASE_URL=""

# Turso auth token (from: turso db tokens create <db-name>)
TURSO_AUTH_TOKEN=""
