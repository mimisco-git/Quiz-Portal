# ─── LOCAL DEVELOPMENT ──────────────────────────────────────────────
# SQLite file used when TURSO_DATABASE_URL is not set.
# Path is relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# JWT signing secret — use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-secret"

# ─── PRODUCTION (Turso) ─────────────────────────────────────────────
# Set these in Vercel → Settings → Environment Variables.
# Leave blank locally; the app falls back to the SQLite file above.

# Your Turso database URL — format: libsql://<db-name>-<org>.turso.io
TURSO_DATABASE_URL=""

# Turso auth token (from: turso db tokens create <db-name>)
TURSO_AUTH_TOKEN=""
